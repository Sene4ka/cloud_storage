# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgrespwd
DB_NAME=cloud_storage
DB_SSLMODE=disable

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispwd
REDIS_DB=0

# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=minio_server_hostname_or_ip:9000
MINIO_ACCESS_KEY=minioaccesskey # MinIO login
MINIO_SECRET_KEY=miniosecretkey # MinIO password
MINIO_USE_SSL=false
MINIO_BUCKET=cloud-storage
MINIO_REGION=ru-central-1

#Prometheus
PROMETHEUS_PORT=9090

#Grafana
GF_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false
GF_PROVISIONING_ENABLED=true

#Node Explorer
NODE_EXPLORER_PORT=9100

# JWT Configuration
JWT_SECRET=your-secret-key
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

#SMTP
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_EMAIL_ADDRESS=from@example.com
SMTP_USERNAME=your_smtp_app_username
SMTP_PASSWORD=your_smtp_app_password

# Service Addresses
AUTH_SERVICE_ADDR=cloud_storage_auth:50051
METADATA_SERVICE_ADDR=cloud_storage_metadata:50052
FILE_SERVICE_ADDR=cloud_storage_file:50053
MAIL_SERVICE_ADDR=cloud_storage_mail:50054

#Metrics ports
AUTH_METRICS_PORT=9002
METADATA_METRICS_PORT=9003
FILE_METRICS_PORT=9004
MAIL_METRICS_PORT=9005