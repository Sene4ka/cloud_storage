# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgrespwd
DB_NAME=cloud_storage
DB_SSLMODE=disable

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispwd
REDIS_DB=0

# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=minio_server_hostname_or_ip:9000
MINIO_ACCESS_KEY=minioaccesskey # MinIO login
MINIO_SECRET_KEY=miniosecretkey # MinIO password
MINIO_USE_SSL=false
MINIO_BUCKET=cloud-storage
MINIO_REGION=ru-central-1

# JWT Configuration
JWT_SECRET=your-secret-key
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

#SMTP
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_MAIL=your.email.address@yandex.ru
SMTP_USERNAME=your_smtp_app_username
SMTP_PASSWORD=your_smtp_app_password

# Service Addresses
AUTH_SERVICE_ADDR=auth-service:50051
METADATA_SERVICE_ADDR=metadata-service:50052
FILE_SERVICE_ADDR=file-service:50053
MAIL_SERVICE_ADDR=mail-service:50054